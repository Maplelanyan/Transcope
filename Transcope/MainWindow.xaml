<Window x:Class="Transcope.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Transcope"
        Width="1320"
        Height="860"
        MinWidth="1080"
        MinHeight="700"
        Background="#0E1014"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="WindowBrush" Color="#0E1014" />
        <SolidColorBrush x:Key="ShellBrush" Color="#141821" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1A1F2B" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#202636" />
        <SolidColorBrush x:Key="InputBrush" Color="#111621" />
        <SolidColorBrush x:Key="StrokeBrush" Color="#2B3447" />
        <SolidColorBrush x:Key="StrokeStrongBrush" Color="#3B4760" />
        <SolidColorBrush x:Key="TextBrush" Color="#F4F7FB" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#95A0B5" />
        <SolidColorBrush x:Key="AccentBrush" Color="#58A6FF" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#7BB8FF" />
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#3B8CE9" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#2FA36B" />
        <SolidColorBrush x:Key="WarningBrush" Color="#D79B3D" />

        <CornerRadius x:Key="PanelRadius">8</CornerRadius>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentPressedBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#232A3B" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A3348" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#4A5A7B" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D2432" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#3D4A67" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="40" />
        </Style>

        <Style x:Key="OutputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="#121722" />
            <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="FontFamily" Value="Cascadia Code" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Border Margin="18"
                Background="{StaticResource ShellBrush}"
                BorderBrush="#20283A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Transcope"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="实时 OCR / 翻译覆盖"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="14" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Background="#162033"
                                BorderBrush="#2A3C5D"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                Margin="0,0,10,0">
                            <TextBlock x:Name="MetricsText"
                                       Text="Lines: 0 / Words: 0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontFamily="Cascadia Code"
                                       FontSize="12" />
                        </Border>

                        <Border Background="#17263E"
                                BorderBrush="#2E4D7E"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8">
                            <TextBlock x:Name="EngineBadgeText"
                                       Text="ENGINE: IDLE"
                                       FontFamily="Cascadia Code"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.04*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="0.96*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="输入"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="ImagePathText"
                                               Text="未选择图片或截图区域"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top"
                                           ItemHeight="40"
                                           Orientation="Horizontal">
                                    <Button x:Name="CaptureScreenButton"
                                            Content="截图"
                                            Click="CaptureScreenButton_Click"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button x:Name="SelectRealtimeRegionButton"
                                            Content="选择区域"
                                            Click="SelectRealtimeRegionButton_Click"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button x:Name="StartRealtimeButton"
                                            Content="Add Overlay"
                                            Click="StartRealtimeButton_Click"
                                            IsEnabled="False"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="选择图片"
                                            Click="PickImageButton_Click"
                                            Margin="0,0,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </Grid>

                            <Border Grid.Row="2"
                                    Background="{StaticResource PanelAltBrush}"
                                    BorderBrush="{StaticResource StrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    ClipToBounds="True">
                                <Grid>
                                    <Image x:Name="PreviewImage"
                                           Stretch="Uniform" />
                                    <StackPanel HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="EmptyPreviewText"
                                                   Text="预览区"
                                                   FontSize="26"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                        <TextBlock Text="图片或区域截图会显示在这里"
                                                   Margin="0,8,0,0"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource MutedTextBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="0">
                                    <TextBlock Text="OCR 引擎"
                                               Style="{StaticResource SectionLabelStyle}" />
                                    <ComboBox x:Name="EngineSelectionBox"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Auto - 优先 PaddleOCR，失败后回退"
                                                      Tag="Auto" />
                                        <ComboBoxItem Content="PaddleOCR"
                                                      Tag="PaddleOcr" />
                                        <ComboBoxItem Content="Windows App SDK AI OCR"
                                                      Tag="WindowsAppSdk" />
                                        <ComboBoxItem Content="Windows.Media.Ocr"
                                                      Tag="WindowsMedia" />
                                        <ComboBoxItem Content="Tesseract OCR"
                                                      Tag="Tesseract" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Row="0"
                                            Grid.Column="2">
                                    <TextBlock Text="识别语言"
                                               Style="{StaticResource SectionLabelStyle}" />
                                    <TextBox x:Name="LanguageTextBox"
                                             Text="zh-Hans"
                                             ToolTip="例如 zh-Hans、en-US、ja-JP，Tesseract 也支持 chi_sim、eng 等 traineddata 代码。" />
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Grid.ColumnSpan="3">
                                    <TextBlock Text="PaddleOCR 模式"
                                               Style="{StaticResource SectionLabelStyle}" />
                                    <ComboBox x:Name="PaddleRuntimeModeBox"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="CPU"
                                                      Tag="Cpu" />
                                        <ComboBoxItem Content="GPU (RTX 5060 / CUDA)"
                                                      Tag="Gpu" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="输出"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="StatusText"
                                               Text="等待输入"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>

                                <WrapPanel Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Top">
                                    <Button x:Name="CancelButton"
                                            Content="取消"
                                            Click="CancelButton_Click"
                                            IsEnabled="False"
                                            Margin="0,0,8,8"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <Button x:Name="RunOcrButton"
                                            Content="开始 OCR"
                                            Click="RunOcrButton_Click"
                                            IsEnabled="False"
                                            Margin="0,0,8,8"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button x:Name="TranslateButton"
                                            Content="翻译"
                                            Click="TranslateButton_Click"
                                            IsEnabled="False"
                                            Margin="0,0,0,8"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="OCR 结果"
                                           Style="{StaticResource SectionLabelStyle}" />
                                <TextBox Grid.Row="2"
                                         x:Name="ResultTextBox"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource OutputTextBoxStyle}"
                                         Text="OCR 结果会显示在这里。" />
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.9*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="1.1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="目标语言"
                                               Style="{StaticResource SectionLabelStyle}" />
                                    <ComboBox x:Name="TargetLanguageBox"
                                              ToolTip="选择翻译输出语言。">
                                        <ComboBoxItem Content="简体中文"
                                                      Tag="zh-Hans" />
                                        <ComboBoxItem Content="English"
                                                      Tag="en" />
                                        <ComboBoxItem Content="日本語"
                                                      Tag="ja" />
                                        <ComboBoxItem Content="한국어"
                                                      Tag="ko" />
                                        <ComboBoxItem Content="繁體中文"
                                                      Tag="zh-Hant" />
                                        <ComboBoxItem Content="Français"
                                                      Tag="fr" />
                                        <ComboBoxItem Content="Deutsch"
                                                      Tag="de" />
                                        <ComboBoxItem Content="Español"
                                                      Tag="es" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="DeepSeek API Key"
                                               Style="{StaticResource SectionLabelStyle}" />
                                    <PasswordBox x:Name="DeepSeekApiKeyBox"
                                                 ToolTip="留空时读取 DEEPSEEK_API_KEY 环境变量。" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="翻译结果"
                                           Style="{StaticResource SectionLabelStyle}" />
                                <TextBox Grid.Row="2"
                                         x:Name="TranslationTextBox"
                                         AcceptsReturn="True"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Style="{StaticResource OutputTextBoxStyle}"
                                         Text="翻译结果会显示在这里。" />
                            </Grid>

                            <DockPanel Grid.Row="8"
                                       LastChildFill="False">
                                <Border DockPanel.Dock="Left"
                                        Background="#142131"
                                        BorderBrush="#28415F"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,6">
                                    <TextBlock Text="本地模式"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>

                                <Border DockPanel.Dock="Right"
                                        Background="#18281F"
                                        BorderBrush="#2B5A42"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,6">
                                    <TextBlock Text="Overlay Ready"
                                               Foreground="#B8EBCF"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
